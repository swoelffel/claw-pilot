{
  "env": {
    "node": true,
    "es2022": true
  },
  "rules": {
    "no-console": "off",
    "no-unused-vars": "warn",
    "prefer-const": "error",
    "no-var": "error",
    "eqeqeq": "error",
    "no-implicit-coercion": "warn",
    "no-return-assign": "error",
    "no-throw-literal": "error"
  }
}
