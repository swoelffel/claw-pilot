{
  "name": "claw-pilot",
  "version": "0.48.1",
  "description": "Orchestrator for claw-runtime multi-agent instances",
  "type": "module",
  "license": "MIT",
  "bin": {
    "claw-pilot": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown && pnpm build:ui",
    "build:cli": "tsdown",
    "build:ui": "vite build ui/",
    "test": "vitest",
    "test:run": "vitest run",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "lint": "oxlint src/",
    "lint:ui": "oxlint ui/src/",
    "lint:all": "pnpm lint && pnpm lint:ui",
    "typecheck": "tsc --noEmit",
    "typecheck:ui": "tsc -p ui/tsconfig.json --noEmit",
    "typecheck:all": "pnpm typecheck && pnpm typecheck:ui",
    "format": "prettier --write \"src/**/*.ts\" \"ui/src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"ui/src/**/*.ts\"",
    "build:safe": "pnpm typecheck:all && pnpm build",
    "knip": "knip",
    "check:circular": "madge --circular --extensions ts src/",
    "spellcheck": "cspell --config cspell.json \"src/**/*.ts\" \"ui/src/**/*.ts\"",
    "prepare": "lefthook install"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "files": [
    "dist/",
    "templates/",
    "install.sh"
  ],
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "lefthook"
    ],
    "overrides": {}
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.58",
    "@ai-sdk/google": "^3.0.43",
    "@ai-sdk/openai": "^3.0.41",
    "@inquirer/prompts": "^7",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@openrouter/ai-sdk-provider": "^2.3.0",
    "ai": "^6.0.116",
    "better-sqlite3": "^11",
    "chalk": "^5",
    "cli-table3": "^0.6",
    "commander": "^13",
    "dompurify": "^3.3.2",
    "hono": "^4.12.7",
    "marked": "^15.0.0",
    "nanoid": "^5",
    "ora": "^8",
    "ws": "^8",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@cspell/dict-fr-fr": "^2.3.2",
    "@hono/node-server": "^1.19.11",
    "@types/better-sqlite3": "^7",
    "@types/dompurify": "^3.0.0",
    "@types/node": "^22",
    "@types/ws": "^8",
    "@vitest/coverage-v8": "^3.2.4",
    "cspell": "^9.7.0",
    "knip": "^5.86.0",
    "lefthook": "^2.1.3",
    "@lit/localize": "^0.12.2",
    "lit": "^3",
    "madge": "^8.0.0",
    "oxlint": "^1.49.0",
    "prettier": "^3.8.1",
    "tsdown": "^0.20.3",
    "typescript": "~5.8",
    "vite": "^6",
    "vitest": "^3"
  }
}
